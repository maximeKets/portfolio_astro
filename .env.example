# ============================================
# Portfolio Environment Variables
# ============================================
#
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# --------------------------------------------
# Required: AI Chat Integration
# --------------------------------------------
# This enables the interactive terminal chatbot feature
OPENAI_API_KEY=your_api_key_here

# Le modèle d'intelligence artificielle utilisé pour générer les réponses (ex: gpt-3.5-turbo, llama3-8b-8192, etc.)
OPENAI_MODEL=your_model_name_here

# --------------------------------------------
# Optional: Site Configuration
# --------------------------------------------
# Your production website URL (used for SEO and sitemap generation)
# PUBLIC_SITE_URL=https://your-website-url.com

# --------------------------------------------
# Optional: fetch private github repo
# --------------------------------------------
# Token d'accès personnel GitHub (Classic ou Fine-grained) pour récupérer vos dépôts privés
GITHUB_TOKEN=your_github_token_here

# --------------------------------------------
# Optional: Notifications via Pushover
# --------------------------------------------
# Clé utilisateur Pushover pour recevoir les notifications sur vos appareils
PUSHOVER_USER=your_pushover_user_key_here

# Token API de votre application Pushover
PUSHOVER_TOKEN=your_pushover_api_token_here

# --------------------------------------------
# Supabase Configuration
# --------------------------------------------
# L'URL de l'API de votre projet Supabase
SUPABASE_URL=https://your-project-id.supabase.co

# La clé publique anonyme pour accéder à votre projet Supabase
SUPABASE_ANON_KEY=your_supabase_anon_key_here